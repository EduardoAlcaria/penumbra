{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Penumbra",
  "version": "0.1.0",
  "identifier": "com.penumbra.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8788",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Penumbra",
        "width": 1200,
        "height": 820,
        "minWidth": 940,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../../backend/target/penumbra-backend-0.1.0.jar": "penumbra-backend.jar"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
